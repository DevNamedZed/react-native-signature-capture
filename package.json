{
  "name": "react-native-signature-capture",
  "version": "1.0.0",
  "description": "Lets users sign their signatures",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native-signature-capture.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "test:android": "cd android && ./gradlew test",
    "test:ios": "xcodebuild test -project ios/RSSignatureCapture.xcodeproj -scheme RSSignatureCapture -destination 'platform=iOS Simulator,name=iPhone 16' -quiet",
    "test:all": "npm test && npm run test:android && npm run test:ios",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "codegenConfig": {
    "name": "RSSignatureViewSpec",
    "type": "components",
    "jsSrcsDir": "src"
  },
  "keywords": [
    "react-component",
    "react-native",
    "ios",
    "android",
    "signature"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DevNamedZed/react-native-signature-capture.git"
  },
  "author": "RepairShopr",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DevNamedZed/react-native-signature-capture/issues"
  },
  "homepage": "https://github.com/DevNamedZed/react-native-signature-capture#readme",
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-builder-bob": "^0.30.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
